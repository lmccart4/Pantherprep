rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: authenticated paps.net user
    function isPapsUser() {
      return request.auth != null && request.auth.token.email.matches('.*@paps\\.net$');
    }

    // Students can write their own profile
    match /students/{uid} {
      allow read: if isPapsUser();
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Sessions - students write their own, teachers read all
    match /sessions/{sessionId} {
      allow read: if isPapsUser();
      allow create: if isPapsUser();
    }
    // Question analytics - any authenticated user can read/write
    match /questionStats/{qId} {
      allow read: if isPapsUser();
      allow write: if isPapsUser();
    }
    // Custom questions - any authenticated paps.net user can read/create
    match /customQuestions/{qId} {
      allow read: if isPapsUser();
      allow create: if isPapsUser();
    }
    // Session auto-save progress - users can only access their own progress
    match /progress/{progressId} {
      allow read: if request.auth != null && progressId.matches(request.auth.uid + '_.*');
      allow write: if request.auth != null && progressId.matches(request.auth.uid + '_.*');
    }
    // Classes - teachers create/manage, students read
    match /classes/{classId} {
      allow read: if isPapsUser();
      allow create: if isPapsUser();
      allow update: if isPapsUser();
    }
    // Questions - seeded via admin SDK, read-only for authenticated users
    match /questions/{qId} {
      allow read: if isPapsUser();
      allow write: if false;
    }
    // Translation cache - Cloud Function manages this, no client access needed
    match /translations/{translationId} {
      allow read: if false;
      allow write: if false;
    }

    // ── ADAPTIVE ENGINE COLLECTIONS ──

    // Performance Log — granular per-answer tracking
    // Students can only write their own answers
    match /performanceLog/{uid}/answers/{answerId} {
      allow read: if isPapsUser() && (
        request.auth.uid == uid ||
        isTeacher(request.auth.uid)
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false; // Answers are immutable
    }

    // Adaptive Profile — computed mastery state
    match /adaptiveProfile/{uid} {
      allow read: if isPapsUser() && (
        request.auth.uid == uid ||
        isTeacher(request.auth.uid)
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Question Pool — normalized question bank for adaptive practice
    match /questionPool/{questionId} {
      allow read: if isPapsUser();
      allow write: if isPapsUser() && isTeacher(request.auth.uid);
    }

    // Helper: check if user has teacher role via students collection
    function isTeacher(uid) {
      return exists(/databases/$(database)/documents/students/$(uid)) &&
        get(/databases/$(database)/documents/students/$(uid)).data.role == "teacher";
    }
  }
}
